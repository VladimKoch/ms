            const data = await response.json();

            // 2. Vymažeme starý obsah tabulky
            tableBody.innerHTML = '';

            // 3. Projdeme data a vytvoříme řádky
            data.forEach(row => {
                // Pozor: Názvy sloupců (row.id, row.email...) musí sedět s vaší databází!
                const htmlRow = `
                    <tr>
                        <td><b>${row.id}</b></td>
                        
                        <td>${row.name|| '-'}</td>
                        <td>${row.email|| '-'}</td>
                       
                        
                        <td>

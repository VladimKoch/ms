{layout '@admin.latte'}
{block content}

<main class="main-content">
<div class="container mt-5">
    <h1 class="mb-4">Administrace Uživatelů</h1>

    <div class="d-flex gap-1 form-control justify-content-start">
    
    <a n:href="refreshUsers!" class="btn btn-primary mb-3 ajax">
    <i class="fa fa-sync"></i>Načíst data</a>

 <form action="{link this}" method="get" class="ajax" data-naja-history="off" id="userSearchForm">
    <div class="input-group mb-3">
        <input type="text" 
               name="userSearch" 
               id="liveSearchInput" 
               value="{$userSearch}" 
               class="form-control" 
               placeholder="Hledat uživatele..." 
               autocomplete="off">
               
        <span class="input-group-text d-none" id="searchSpinner">
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        </span>

        {* <button class="btn btn-primary" type="submit">Hledat</button> *}
        
        {* <a n:href="refreshUsers!" n:if="$userSearch" class="btn btn-outline-secondary ajax">
            ✕
        </a> *}
    </div>
</form>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="" style="background-color: #227dd8ff;color:purple">
                        <tr>
                            <th>id</th>
                            <th>username</th>
                            <th>email</th>
                            <th>role</th>
                            <th>createdOn</th>
                        </tr>
                    </thead>
                        
                    <tbody n:snippet="tabulkaZaznamu">
                      {foreach $peoples as $people}
                        <tr>
                            <td>{$people->id}</td>
                            <td>{$people->username}</td>
                            <td>{$people->email}</td>
                            <td>{$people->role}</td>
                            <td>{$people->createdOn}</td>
                        </tr>
                    {else}
                        <tr>
                            <td colspan="15" class="text-center">Žádné záznamy</td>
                        </tr>
                    {/foreach}
                        
                        {* <tr><td colspan="5" class="text-center">Načítám data...</td></tr> *}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
 </main>


{* <script n:syntax="off">
    document.addEventListener("DOMContentLoaded", function() {
        loadData(); // Načíst data ihned po startu
        
        // Funkce pro načtení dat
        document.getElementById('btn-reload').addEventListener('click', loadData);
    });

    async function loadData() {
        const tableBody = document.getElementById('data-container');
        
        try {
            // 1. Zavoláme vaše API (ApiPresenter)
            // Upravte 'table=users' podle názvu vaší tabulky v DB

                            <button class="btn btn-sm btn-danger" onclick="deleteItem(${row.id})">Smazat</button>
                        </td>
                    </tr>
                `;
                tableBody.innerHTML += htmlRow;
            });

        } catch (error) {
            console.error('Chyba:', error);
            tableBody.innerHTML = '<tr><td colspan="4" class="text-danger">Chyba při načítání dat!</td></tr>';
        }
    }

    // Funkce pro tlačítka (zatím jen alert)
    function editItem(id) {
        alert('Edituji ID: ' + id);
        // Tady později napojíme odeslání dat na API
    }
    
    function deleteItem(id) {
        if(confirm('Opravdu smazat ID ' + id + '?')) {
            alert('Mazání ID: ' + id);
        }
    }
</script>

<script>
    // 1. Definujeme funkci (aby byla dostupná globálně)
    function loadMyApiData() {
        console.log("Načítám data z API...");
        // ... zde je váš fetch kód ...

</script> *}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        let timeout = null;
        const spinner = document.getElementById('searchSpinner');

        // POSLOUCHÁME NA CELÉM TĚLE DOKUMENTU (Event Delegation)
        // Díky tomu to funguje i po překreslení AJAXem
        document.body.addEventListener('input', function (e) {

            // Zkontrolujeme, zda událost vyvolal náš input (podle ID)
            if (e.target && e.target.id === 'liveSearchInput') {
                
                const form = e.target.closest('form');

                // 1. Zobrazíme spinner
                if (spinner) spinner.classList.remove('d-none');

                // 2. Resetujeme odpočet
                clearTimeout(timeout);

                // 3. Spustíme nový odpočet
                timeout = setTimeout(function () {
                    // Odešleme formulář
                    // Toto automaticky zachytí Nette/Naja script
                    if (form) {
                        form.requestSubmit();
                    }
                }, 500);
            }
        });
        
        // --- Vypnutí spinneru po dokončení AJAXu ---
        
        // Verze pro Naja (moderní Nette)
        if (typeof naja !== "undefined") {
            naja.addEventListener('complete', () => {
                if (spinner) spinner.classList.add('d-none');
            });
        }
        
        // Verze pro jQuery / nette.ajax.js (starší)
        if (typeof $ !== "undefined") {
             $(document).ajaxComplete(function() {
                $('#searchSpinner').addClass('d-none');
             });
        }
    });
</script>
{/block}

<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{ifset title}{include title|stripHtml}MS | {/ifset}MS Domácí e-účetnictví</title>
    <link rel="icon" type="image/x-icon" href="{$basePath}/favicon.ico">
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome pro ikony (náhrada za Lucide) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Moje Styly.css -->
    <link rel="stylesheet" href="{$basePath}/assets/css/styly.css">

</head>
<body class="bg-white d-flex flex-column min-vh-100">
	<!-- --- HLAVIČKA --- -->
	{include header.latte}

	<!-- --- OBSAH STRÁNKY --- -->
	{include content}

	<!-- --- PATIČKA --- -->
	{include footer.latte}



	<script src="https://unpkg.com/naja@2/dist/Naja.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            naja.initialize();
        });
    </script>

	<!-- Bootstrap JS -->
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Flash message auto-hide script -->
    <script>
        setTimeout(function() {
            let alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                let bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>



	

	
    <script src="https://nette.github.io/resources/js/3/netteForms.min.js"></script>

<script>
    {syntax off} // Vypneme Latte syntaxi, abychom mohli psát čistý JS

    // Přepíšeme výchozí funkci Nette, která dělá ty ošklivé alerty
    Nette.showFormErrors = function(form, errors) {
        // 1. Nejprve vyčistíme staré chyby (odstraníme červené rámečky)
        var inputs = form.querySelectorAll('.is-invalid');
        for (var i = 0; i < inputs.length; i++) {
            inputs[i].classList.remove('is-invalid');
        }

        // 2. Pokud jsou chyby, projdeme je
        if (errors.length > 0) {
            // Zaměříme se na první prvek s chybou
            var firstErrorInput = errors[0].element;
            
            // Projdeme všechny chyby
            for (var i = 0; i < errors.length; i++) {
                var error = errors[i];
                var input = error.element;
                
                // Přidáme Bootstrap třídu pro červený rámeček
                input.classList.add('is-invalid');

                // Najdeme pod inputem div s třídou 'invalid-feedback' a změníme mu text
                // Předpokládáme strukturu: input + div.invalid-feedback
                var feedback = input.nextElementSibling; 
                if (feedback && feedback.classList.contains('invalid-feedback')) {
                    feedback.innerText = error.message;
                }
            }

            // Skrolujeme k první chybě a dáme do ní kurzor
            firstErrorInput.focus();
        }
    };
    {/syntax}
</script>
</body>
</html>